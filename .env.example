# HirKaar — one `.env` for local Docker (api + web + db) and copy-paste into Render/Vercel dashboards.
# Copy:  cp .env.example .env
#
# ── PostgreSQL (Docker `db` service + API defaults) ─────────────────────────
POSTGRES_USER=hirekaar
POSTGRES_PASSWORD=hirekaar
POSTGRES_DB=hirekaar
# Inside Docker Compose the API reaches Postgres at host `db`, port 5432.
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Host machine → container (change if 5433 is taken)
POSTGRES_PUBLISHED_PORT=5433

# Optional: full URL (overrides POSTGRES_* for the API + Alembic). Use for Neon / RDS:
# DATABASE_URL=postgresql+psycopg2://USER:PASS@ep-xxxx.neon.tech/neondb?sslmode=require

# ── FastAPI ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
PLATFORM_FEE_RATE=0.10
BOOST_PRICE_PER_DAY_MINOR=500
CORS_ORIGINS=http://localhost:3000

# ── Next.js (server proxy + browser) ─────────────────────────────────────────
# Server-side only: FastAPI base URL (no trailing slash). In Compose use service name `api`.
API_BASE_URL=http://api:8000
# Legacy alias (optional): API_INTERNAL_URL=http://api:8000

# Public URL of the Next app as the browser uses it
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional published ports (defaults match below)
# API_PUBLISHED_PORT=8000
# WEB_PUBLISHED_PORT=3000
